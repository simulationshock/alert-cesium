{
  models: {
    mode: "merge",
    providers: {
      nvidia: {
        baseUrl: "https://integrate.api.nvidia.com/v1",
        apiKey: { source: "env", provider: "default", id: "NVIDIA_LLM_API" },
        auth: "api-key",
        authHeader: true,
        api: "openai-completions",
        timeoutSeconds: 120,
        models: [
          {
            id: "qwen/qwen3-coder-480b-a35b-instruct",
            name: "Qwen3 Coder 480B A35B Instruct (NVIDIA)",
            contextWindow: 200000,
            contextTokens: 200000,
            maxTokens: 4096,
            input: ["text"],
            reasoning: false,
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            compat: { supportsTools: true }
          },
          {
            id: "z-ai/glm4.7",
            name: "GLM 4.7 (NVIDIA)",
            contextWindow: 200000,
            contextTokens: 200000,
            maxTokens: 16384,
            input: ["text"],
            reasoning: true,
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            params: {
              temperature: 1,
              top_p: 1,
              max_tokens: 16384,
              seed: 42,
              chat_template_kwargs: {
                enable_thinking: true,
                clear_thinking: false
              }
            },
            compat: { supportsTools: true }
          },
          {
            id: "minimaxai/minimax-m2.7",
            name: "MiniMax M2.7 (NVIDIA)",
            contextWindow: 200000,
            contextTokens: 200000,
            maxTokens: 16384,
            input: ["text"],
            reasoning: false,
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            params: {
              temperature: 1,
              top_p: 0.95,
              max_tokens: 16384
            },
            compat: { supportsTools: true }
          }
        ]
      }
    }
  },
  agents: {
    defaults: {
      models: {
        "nvidia/qwen/qwen3-coder-480b-a35b-instruct": { alias: "NVIDIA Qwen3 Coder 480B A35B Instruct" },
        "nvidia/z-ai/glm4.7": { alias: "NVIDIA GLM 4.7" },
        "nvidia/minimaxai/minimax-m2.7": { alias: "NVIDIA MiniMax M2.7" }
      }
    }
  }
}
